# HerAgent 积分服务 — 环境变量配置
# 复制此文件为 .env 并填入实际值

# === 必需 ===
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# === 安全（生产环境务必修改）===
HERMES_JWT_SECRET=生成一个随机字符串：openssl rand -hex 32

# === 短信（可选，dev模式打印到控制台）===
HERMES_SMS_MODE=dev
# TENCENT_SECRET_ID=
# TENCENT_SECRET_KEY=
# TENCENT_SMS_APP_ID=
# TENCENT_SMS_TEMPLATE_ID=

# === 微信登录（可选）===
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=

# === 服务 ===
HERMES_BASE_URL=https://api.heragent.io
