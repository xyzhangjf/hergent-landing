# Hergent 积分服务 — 环境变量配置
# 复制此文件为 .env 并填入实际值

# ===== 必填 =====
# DeepSeek API Key（用于代理聊天请求）
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# JWT 密钥（用于 session token 签名）
# 留空则自动生成随机密钥（服务重启后所有 session 失效）
HERMES_JWT_SECRET=

# ===== 服务配置 =====
# 监听地址和端口
HERMES_HOST=0.0.0.0
HERMES_PORT=8765

# 服务基础 URL（用于微信 OAuth 回调等）
HERMES_BASE_URL=https://api.hergent.io

# ===== 短信配置 =====
# 模式: dev（控制台打印）| tencent（腾讯云短信）
HERMES_SMS_MODE=dev

# 腾讯云短信（HERMES_SMS_MODE=tencent 时必填）
# TENCENT_SECRET_ID=
# TENCENT_SECRET_KEY=
# TENCENT_SMS_APP_ID=
# TENCENT_SMS_SIGN=Hergent
# TENCENT_SMS_TEMPLATE_ID=

# ===== 微信登录（可选）=====
# 需要微信开放平台账号
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=
